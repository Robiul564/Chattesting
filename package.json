{
  "name": "whatsapp-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant WhatsApp Business Platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:enable-vector": "prisma db execute --file prisma/sql/enable-vector.sql --schema prisma/schema.prisma",
    "render:build": "npm ci && npm run prisma:generate && npm run db:enable-vector && npm run db:push && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bullmq": "^5.12.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "prisma": "^5.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
